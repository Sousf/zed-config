[
  {
    "context": "Workspace",
    "bindings": {
      "cmd-p": "file_finder::Toggle",
      "ctrl-tab": "pane::ActivateNextItem",
      "ctrl-shift-tab": "pane::ActivatePreviousItem",
      "ctrl-w": "pane::CloseActiveItem",
      "ctrl-shift-w": "pane::CloseOtherItems",

      "cmd-b": "editor::GoToDefinition",
      "cmd-shift-f": "project_search::ToggleFocus",
      "cmd-f": "pane::DeploySearch",
      "cmd-j": "terminal_panel::ToggleFocus",
      "cmd-1": "workspace::ToggleLeftDock",
      "cmd-2": "workspace::ToggleRightDock",
      "cmd-3": "workspace::ToggleBottomDock",
      "cmd-d": "project_panel::NewDirectory",
      "cmd-n": "project_panel::NewFile",
      "cmd-shift-a": "agent::ToggleFocus",
      "cmd-shift-p": "command_palette::Toggle",
      "cmd-r": "editor::Rename",
    },
  },

  {
    "context": "Editor",
    "bindings": {
      // LSP navigation – exact Rider defaults
      "f12": "editor::GoToDefinition", // Go to Declaration (Rider default)
      "cmd-f12": "editor::GoToImplementation", // Go to Implementation
      "cmd-alt-f7": "editor::FindAllReferences", // Find Usages (Rider)
      "cmd-b": "editor::GoToDefinition",
      "cmd-`": "editor::Hover",
    },
  },

  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j j": "vim::NormalBefore",
      "j k": "vim::NormalBefore",
    },
  },

  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "tab": "editor::Indent",
      "shift-tab": "editor::Outdent",
    },
  },
]
